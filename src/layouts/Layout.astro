---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Social Media Manager' } = Astro.props;
const pathname = Astro.url.pathname;
const user = Astro.locals.user;
const isAdmin = user?.type === 'admin';

const postLinks = [
  { href: '/', label: 'Dashboard' },
  { href: '/clients', label: 'Clients' },
  { href: '/pipelines', label: 'Schedule' },
];

const taskLinks = [
  { href: '/tasks', label: 'Dashboard' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class:list={[
    'antialiased bg-gray-50 text-gray-900 min-h-screen',
    isAdmin ? 'flex' : 'flex flex-col',
  ]}>
    {isAdmin ? (
      <>
        <!-- Admin Sidebar -->
        <aside class="w-64 bg-gray-900 text-white min-h-screen flex-shrink-0 flex flex-col">
          <div class="p-6 border-b border-gray-800">
            <h1 class="text-lg font-bold tracking-tight">SM Scheduler</h1>
            <p class="text-xs text-gray-400 mt-1">Social Media Manager</p>
          </div>
          <nav class="flex-1 p-4 space-y-1">
            <p class="px-4 pt-2 pb-1 text-xs font-semibold uppercase tracking-wider text-gray-500">Post Scheduling</p>
            {postLinks.map((link) => {
              const isActive =
                link.href === '/'
                  ? pathname === '/'
                  : pathname.startsWith(link.href);
              return (
                <a
                  href={link.href}
                  class:list={[
                    'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
                    isActive
                      ? 'bg-indigo-600 text-white'
                      : 'text-gray-300 hover:bg-gray-800 hover:text-white',
                  ]}
                >
                  {link.label}
                </a>
              );
            })}
            <p class="px-4 pt-6 pb-1 text-xs font-semibold uppercase tracking-wider text-gray-500">Task Scheduling</p>
            {taskLinks.map((link) => {
              const isActive = pathname.startsWith(link.href);
              return (
                <a
                  href={link.href}
                  class:list={[
                    'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
                    isActive
                      ? 'bg-indigo-600 text-white'
                      : 'text-gray-300 hover:bg-gray-800 hover:text-white',
                  ]}
                >
                  {link.label}
                </a>
              );
            })}
          </nav>
          <div class="p-4 border-t border-gray-800 space-y-1">
            <a
              href="/settings"
              class:list={[
                'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
                pathname.startsWith('/settings')
                  ? 'bg-indigo-600 text-white'
                  : 'text-gray-300 hover:bg-gray-800 hover:text-white',
              ]}
            >
              Settings
            </a>
            <button
              data-logout
              class="w-full text-left block px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-colors"
            >
              Logout
            </button>
          </div>
        </aside>

        <!-- Admin Main content -->
        <main class="flex-1 overflow-auto">
          <div class="max-w-7xl mx-auto px-6 py-8">
            <slot />
          </div>
        </main>
      </>
    ) : (
      <>
        <!-- User Header -->
        <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
          <h1 class="text-lg font-bold text-gray-900">SM Scheduler</h1>
          <button
            data-logout
            class="text-sm text-gray-500 hover:text-gray-700 font-medium transition-colors"
          >
            Logout
          </button>
        </header>

        <main class="flex-1 flex items-center justify-center">
          <div class="max-w-2xl mx-auto px-6 py-8 text-center">
            <slot />
          </div>
        </main>
      </>
    )}

    <script>
      document.querySelector('[data-logout]')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
